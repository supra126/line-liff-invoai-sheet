# ==============================================================================
# 網站資訊
# ==============================================================================

# 網站標題（選填，預設「發票登錄」）
# 顯示於瀏覽器分頁和 SEO meta title
SITE_TITLE=發票登錄

# ==============================================================================
# LINE LIFF
# ==============================================================================

# LIFF App ID（從 LINE Developers Console 取得）
# 前綴 NEXT_PUBLIC_ 表示前端可存取
# 留空則自動進入開發模式（不需登入 LINE）
NEXT_PUBLIC_LIFF_ID=

# 儲存成功後自動發送到 LINE 聊天室的訊息（選填）
# 設定後，發票成功寫入 Google Sheets 時會透過 liff.sendMessages()
# 在使用者當前的聊天室中發送此訊息
# 需要在 LINE LIFF 設定中勾選 chat_message.write scope
# 留空則不會發送任何訊息
# 支援變數：{user_name} {user_id} {invoice_date} {vendor_name} {invoice_number} {total_amount} {currency} {source}
# 範例：{user_name} 已登錄 {vendor_name} 的發票，金額 {total_amount} 元
NEXT_PUBLIC_LIFF_SUCCESS_MESSAGE={user_name} 已登錄，金額 {total_amount} 元

# ==============================================================================
# Gemini AI
# ==============================================================================

# Google AI Studio API Key（https://aistudio.google.com/apikey）
GEMINI_API_KEY=

# Gemini 模型名稱（選填，預設 gemini-2.5-flash）
#   gemini-2.5-flash — 快速、低成本，適合大多數發票辨識場景
#   gemini-2.5-pro   — 更高精度，適合模糊/手寫/複雜版面的發票，但回應較慢、成本較高
GEMINI_MODEL=gemini-2.5-flash

# ==============================================================================
# Google Sheets（透過 Google Apps Script）
# ==============================================================================

# Google Apps Script Web App URL
# 設定方式請參考 README.md 及 google-apps-script.js
GOOGLE_APPS_SCRIPT_URL=

# 與 Apps Script 端共用的 secret（自訂隨機字串，防止未授權寫入）
GOOGLE_APPS_SCRIPT_SECRET=
